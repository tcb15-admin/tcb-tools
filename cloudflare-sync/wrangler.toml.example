name = "tcb-tools-sync"
main = "worker.js"
compatibility_date = "2026-04-26"

[[d1_databases]]
binding = "DB"
database_name = "tcb-tools-sync"
database_id = "REPLACE_WITH_YOUR_D1_DATABASE_ID"

[vars]
# 共有トークン（本番では wrangler secret put SYNC_API_TOKEN 推奨）
SYNC_API_TOKEN = "REPLACE_WITH_STRONG_SHARED_TOKEN"
