name = "tcb-tools-sync"
main = "worker.js"
compatibility_date = "2026-04-26"

[[d1_databases]]
binding = "DB"
database_name = "tcb-tools-sync"
database_id = "REPLACE_WITH_YOUR_D1_DATABASE_ID"

# トークンはコミットしないこと。本番: wrangler secret put SYNC_API_TOKEN
# ローカル検証: このディレクトリに .dev.vars を置く（例: SYNC_API_TOKEN=dev-only-...）
